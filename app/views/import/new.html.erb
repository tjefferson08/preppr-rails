<div class="mx-auto md:w-2/3 w-full">
    <h1 class="font-bold text-4xl">Import recipe from URL</h1>

    <%= form_with url: import_path, method: :post do |form| %>
        <%= form.label :url, "URL:" %>
        <%= form.text_field :url %>
        <%= form.submit "Import" %>
    <% end %>

    <%= link_to 'Back to recipes', recipes_path, class: "ml-2 rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
</div>
