<div id="<%= dom_id recipe %>">
  <p class="my-5">
    <strong class="block font-medium mb-1">Name:</strong>
    <%= recipe.name %>
  </p>

  <p class="my-5">
    <strong class="block font-medium mb-1">Description:</strong>
    <%= recipe.description %>
  </p>

  <p class="my-5 p-4">
    <strong class="block font-medium mb-1">Instructions:</strong>
    <ul class="list-disc">
      <% recipe.instructions.each do |i| %>
        <li><%= i %></li>
      <% end %>
    </ul>
  </p>

  <p class="my-5 p-4">
    <strong class="block font-medium mb-1">Ingredients:</strong>
    <ul class="list-disc">
      <% recipe.ingredient_list.each do |i| %>
        <li><%= i %></li>
      <% end %>
    </ul>
  </p>

  <p class="my-5">
    <strong class="block font-medium mb-1">Image url:</strong>
    <%= recipe.image_url %>
  </p>

  <% if action_name != "show" %>
    <%= link_to "Show this recipe", recipe, class: "rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
    <%= link_to 'Edit this recipe', edit_recipe_path(recipe), class: "rounded-lg py-3 ml-2 px-5 bg-gray-100 inline-block font-medium" %>
    <hr class="mt-6">
  <% end %>
</div>
